{
    "name": "mindtwo/laravel-blade-spaceless",
    "description": "Blade @spaceless directive that strips whitespace between HTML tags at render time.",
    "keywords": [
        "laravel",
        "blade",
        "spaceless",
        "directive",
        "html",
        "whitespace"
    ],
    "homepage": "https://github.com/mindtwo/laravel-blade-spaceless",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "mindtwo GmbH",
            "email": "info@mindtwo.de",
            "homepage": "https://www.mindtwo.de/",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.9 || ^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^2.34 || ^3.0",
        "phpstan/phpstan": "^1.11 || ^2.0"
    },
    "autoload": {
        "psr-4": {
            "mindtwo\\Spaceless\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "mindtwo\\Spaceless\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "format": "vendor/bin/pint",
        "format:test": "vendor/bin/pint --test",
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "mindtwo\\Spaceless\\SpacelessServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
